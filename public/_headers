# Global security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=()

# CRITICAL: Never cache index.html — must always fetch fresh from server
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# SPA fallback — all routes serve index.html, so also no-cache
/
  Cache-Control: no-cache, no-store, must-revalidate

# Always revalidate service worker files so updates are picked up quickly
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

# Cache static assets with content hashes for 1 year (immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache demo images for 1 year
/images/demos/*
  Cache-Control: public, max-age=31536000, immutable

# Cache other images for 1 week
/images/*
  Cache-Control: public, max-age=604800

# Cache favicon and static files for 1 week
/*.ico
  Cache-Control: public, max-age=604800

/*.svg
  Cache-Control: public, max-age=604800

# Cache JS and CSS with content hashes
# NOTE: Do NOT use /*.js here — it would conflict with /sw.js no-cache rule.
# Vite outputs all JS/CSS to /assets/* which is already covered above.

# Cache JPG/PNG images
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

# Cache WebP images
/*.webp
  Cache-Control: public, max-age=31536000, immutable

# Cache font files for 1 year
/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Revalidate manifest quickly to avoid stale app metadata
/manifest.webmanifest
  Cache-Control: public, max-age=300, must-revalidate
